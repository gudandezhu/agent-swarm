# E2E 测试 Docker 环境
# 模拟全新用户环境测试 agent-swarm

FROM node:18-alpine

# 设置工作目录
WORKDIR /app

# 安装必要的系统依赖
RUN apk add --no-cache git

# 复制项目文件
COPY package*.json ./
COPY tsconfig.json ./
COPY .eslintrc.js ./
COPY .prettierrc ./

# 复制源代码
COPY src ./src
COPY agents ./agents

# 安装依赖
RUN npm ci

# 编译项目
RUN npm run build

# 复制测试文件
COPY tests ./tests
COPY vitest.config.ts ./

# 设置测试命令
CMD ["npm", "test", "--", "--run"]
