{
  "name": "agent-swarm",
  "version": "0.1.0",
  "description": "多 Agent 协作框架 - 快速创建 Agent，统一消息路由，Session 持久化",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "swarm": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "npm install && npm run build && node dist/setup/init-workspace.js",
    "dev": "bun src/cli.ts",
    "dev:watch": "bun --watch src/cli.ts",
    "start": "bun src/cli.ts",
    "start:tui": "bun src/cli.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint dist",
    "format": "prettier --write src"
  },
  "keywords": [
    "agent",
    "swarm",
    "llm",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@oh-my-pi/pi-natives": "^13.3.7",
    "croner": "^10.0.1",
    "ink": "^6.8.0",
    "ink-multiline-input": "^0.1.0",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.1",
    "openai": "^6.27.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
