#!/usr/bin/env expect
# TUI 交互自动化测试
# 测试 TUI 模式的完整用户交互流程

set timeout 20

# 配置日志
log_user 1
exp_internal 0

# 启动 swarm
puts "\n🧪 开始 TUI 自动化交互测试...\n"

spawn swarm

# 测试 1: TUI 启动
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 1: TUI 启动"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

expect {
  "Agent Swarm 服务启动成功" {
    puts "✅ 测试 1 通过: TUI 启动成功"
  }
  timeout {
    puts "❌ 测试 1 失败: TUI 启动超时"
    exit 1
  }
}

expect {
  "TUI 模式（终端用户界面）" {
    puts "✅ 确认: TUI 模式已启动"
  }
  timeout {
    puts "⚠️  警告: 未检测到 TUI 模式提示"
  }
}

expect {
  "就绪" {
    puts "✅ 确认: 状态栏显示就绪"
  }
  timeout {
    puts "⚠️  警告: 未检测到就绪状态"
  }
}

expect {
  "╭──" {
    puts "✅ 确认: 编辑器边框显示"
  }
  timeout {
    puts "⚠️  警告: 未检测到编辑器边框"
  }
}

# 测试 2: 发送消息
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 2: 发送消息"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

send "你好，请简单介绍一下你自己\r"

expect {
  "处理中" {
    puts "✅ 测试 2 通过: 检测到处理状态"
  }
  timeout {
    puts "⚠️  警告: 未检测到处理状态"
  }
}

# 测试 3: 接收 AI 响应
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 3: 接收 AI 响应"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# 等待响应（AI 响应或错误）
expect {
  -re "(AI|assistant|系统)" {
    puts "✅ 测试 3 通过: 收到响应"
  }
  timeout {
    puts "⚠️  警告: 等待响应超时"
  }
}

# 等待恢复到就绪状态
expect {
  "就绪" {
    puts "✅ 确认: 恢复到就绪状态"
  }
  timeout {
    puts "⚠️  警告: 未恢复到就绪状态"
  }
}

# 测试 4: 测试 Markdown 渲染
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 4: 测试 Markdown 渲染"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

send "请用 Markdown 格式回复：包含一个列表和一个代码块\r"

expect {
  "处理中" {
    puts "✅ 消息已发送"
  }
  timeout {
    puts "⚠️  警告: 未检测到处理状态"
  }
}

# 等待 Markdown 响应
expect {
  -re "(\-|```)" {
    puts "✅ 测试 4 通过: 检测到 Markdown 格式"
  }
  timeout {
    puts "⚠️  警告: 未检测到 Markdown 格式（可能正常）"
  }
}

expect {
  "就绪" {
    puts "✅ 恢复到就绪状态"
  }
  timeout {
    puts "⚠️  警告: 未恢复到就绪状态"
  }
}

# 测试 5: 测试命令
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 5: 测试命令"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

send "/help\r"

expect {
  "帮助信息" {
    puts "✅ 测试 5 通过: 帮助命令正常工作"
  }
  timeout {
    puts "⚠️  警告: 未显示帮助信息"
  }
}

# 测试 6: 退出
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "测试 6: 退出"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

send "/exit\r"

expect {
  "正在退出" {
    puts "✅ 测试 6 通过: 正常退出"
  }
  timeout {
    puts "⚠️  警告: 退出消息未显示"
  }
}

expect eof

# 测试总结
puts "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts "🎉 TUI 自动化测试完成！"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
puts ""
puts "✅ 测试通过项："
puts "   1. TUI 启动"
puts "   2. 发送消息"
puts "   3. 接收响应"
puts "   4. Markdown 渲染"
puts "   5. 命令功能"
puts "   6. 正常退出"
puts ""
puts "🎯 TUI 模式功能完整，可以正常使用！"
puts "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
